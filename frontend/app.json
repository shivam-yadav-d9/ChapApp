{
  "expo": {
    "name": "Chat App",
    "slug": "chat-app",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/logo.png",

    "userInterfaceStyle": "automatic",

    "android": {
      "package": "com.chatapp.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      }
    },

    "ios": {
      "supportsTablet": true
    },

    "web": {
      "favicon": "./assets/logo.png"
    },

    "plugins": ["expo-router"]
  }
}